{
  "name": "luminae-helper",
  "version": "1.0.0",
  "description": "Install AI skills to coding tools (Claude Code, Cursor, OpenCode, Trae, etc.)",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "luminae-helper": "src/cli.js"
  },
  "files": [
    "src/cli.js",
    "src/lib/*.js",
    "src/utils/*.js",
    "README.md"
  ],
  "scripts": {
    "start": "node src/cli.js",
    "dev": "node --watch src/cli.js"
  },
  "keywords": [
    "claude",
    "cursor",
    "opencode",
    "trae",
    "skills",
    "ai-toolkit",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evenweiss/ai-toolkit.git",
    "directory": "tools/luminae-helper"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.3.0",
    "gradient-string": "^3.0.0",
    "wcwidth": "^1.0.1"
  }
}
